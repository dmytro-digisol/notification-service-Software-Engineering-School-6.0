PORT=3535
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/notification?appName=Github-Notification-Service
LOG_LEVEL=info

# GitHub API (optional — avoids rate limiting)
GITHUB_TOKEN=

# SendPulse transactional email (https://sendpulse.com/integrations/api)
# Generate a static API key in SendPulse account settings → API
SENDPULSE_API_KEY=<Key>
SENDPULSE_SENDER_EMAIL=dmytro@digisol.agency
SENDPULSE_SENDER_NAME=GitHub Notifier

# Cron schedule for checking new releases (default: every 5 minutes)
CHECK_INTERVAL_CRON=*/5 * * * *

# Redis URL for GitHub API response caching (optional — caching disabled if not set)
REDIS_URL=redis://<user>:<password>@redis-18389.c323.us-east-1-2.ec2.cloud.redislabs.com:18389
