{
  "name": "notification-service",
  "version": "1.0.0",
  "main": "dist/index.js",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "mongodb-memory-server"
    ]
  },
  "scripts": {
    "compile": "tsc",
    "start": "node dist/index.js",
    "build:start": "tsc && node dist/index.js",
    "test": "vitest run",
    "lint": "pnpx @biomejs/biome lint --write --unsafe ./src ./public"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "mongoose": "^7.8.8",
    "node-cron": "^3.0.3",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.1.0",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.3",
    "mongodb-memory-server": "^11.0.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
